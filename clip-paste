#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
if [ -f "${SCRIPT_DIR}/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib-desktop"
else
    . "${CLI_HELPERS_LIBDIR:-/usr/local/lib/cli-helpers}/lib-desktop"
fi

usage() {
    echo "usage: $(basename "${0}") [-n|--new-line] [-c|--clipboard|-p|--primary] [-f|--file <file>]" 1>&2
    exit 1
}

clipboard="primary"
new_line=0
file=""
while [ $# -gt 0 ]; do
    case "${1}" in
        -h|--help)
            usage
            ;;
        -n|--new-line)
            new_line=1
            ;;
        -p|--primary)
            clipboard="primary"
            ;;
        -c|--clipboard)
            clipboard="clipboard"
            ;;
        -f|--file)
            shift
            [ -z "${1}" ] && usage
            file="${1}"
            ;;
        *)
            usage
            ;;
    esac
    shift
done


if cli_helpers_is_wayland; then
    cli_helpers_require_command wl-paste wl-clipboard || exit 1
    if [ "${clipboard}" = "primary" ]; then
        content="$(wl-paste --primary 2>/dev/null)"
    else
        content="$(wl-paste 2>/dev/null)"
    fi
else
    content="$(DISPLAY=$(xdisplay) xclip -o -sel "${clipboard}")"
fi
if [ $new_line -eq 1 ] && [ "${content: -1}" != $'\n' ]; then
    content="${content}"$'\n'
fi

if [ -n "${file}" ]; then
    echo -n "${content}" > "${file}"
else
    echo -n "${content}"
fi
