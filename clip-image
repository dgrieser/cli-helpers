#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
if [ -f "${SCRIPT_DIR}/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib-desktop"
else
    . "${CLI_HELPERS_LIBDIR:-/usr/local/lib/cli-helpers}/lib-desktop"
fi

error() {
    echo "ERROR: ${1}" 1>&2
}

fail() {
    error "${1}"
    exit 1
}

if [ -p /dev/stdin ]; then
    file_path="$(cat -)"
    [ ! -f "$file_path" ] && fail "Failed to find file denoted by stdin"
    mime_type="$(mimetype --output-format "%m" "${file_path}")"
    [ -z "$mime_type" ] && fail "Failed to determine mime type of file"
    if cli_helpers_is_wayland; then
        cli_helpers_require_command wl-copy wl-clipboard || exit 1
        wl-copy --type "${mime_type}" < "${file_path}"
    else
        DISPLAY=$(xdisplay) xclip -sel c -t "${mime_type}" -i "${file_path}"
    fi
else
    fail "No input provided"
fi
