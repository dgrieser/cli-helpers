#!/bin/bash
CLIPBOARD_PRIVATE_FILE="${HOME}/.cache/clipboard-private"
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
if [ -f "${SCRIPT_DIR}/lib/cli-helpers/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib/cli-helpers/lib-desktop"
elif [ -f "${SCRIPT_DIR}/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib-desktop"
else
    . "${CLI_HELPERS_LIBDIR:-/usr/local/lib/cli-helpers}/lib-desktop"
fi

usage() {
    echo "usage: $(basename "${0}") [--print] [-c|--clipboard|-p|--primary] [<file, or stdin>]" 2>&1
    exit 1
}

error() {
    echo "ERROR: ${1}" 2>&1
}

fail() {
    error "${1}"
    exit 1
}

PRINT=0
FILE=""
CLIPBOARD="both"

while [ "${#}" -gt 0 ]; do
    case "${1}" in
        -h|--help)
            usage
            ;;
        --print)
            PRINT=1
            ;;
        -c|--clipboard)
            CLIPBOARD="clipboard"
            ;;
        -p|--primary)
            CLIPBOARD="primary"
            ;;
        *)
            if [ -z "${FILE}" ]; then
                FILE="${1}"
            else
                error "Unexpected argument '${1}'"
                usage
            fi
            ;;
    esac
    shift
done

[ "${FILE}" = "-" ] && FILE=""
[ -n "${FILE}" ] && [ ! -f "${FILE}" ] && fail "File '${FILE}' does not exist"

copy_file() {
    local input_file="${1}"
    touch "${CLIPBOARD_PRIVATE_FILE}" 2>/dev/null || true

    if cli_helpers_is_wayland; then
        cli_helpers_require_command wl-copy wl-clipboard || return 1
        if [ "${CLIPBOARD}" = "clipboard" ] || [ "${CLIPBOARD}" = "both" ]; then
            wl-copy < "${input_file}"
        fi
        if [ "${CLIPBOARD}" = "primary" ] || [ "${CLIPBOARD}" = "both" ]; then
            wl-copy --primary < "${input_file}"
        fi
    else
        if [ "${CLIPBOARD}" = "clipboard" ]; then
            DISPLAY=$(xdisplay) xclip -i -sel c < "${input_file}" &>/dev/null
        elif [ "${CLIPBOARD}" = "primary" ]; then
            DISPLAY=$(xdisplay) xclip -i -sel p < "${input_file}" &>/dev/null
        else
            DISPLAY=$(xdisplay) xclip -i -sel c < "${input_file}" &>/dev/null
            DISPLAY=$(xdisplay) xclip -i -sel p < "${input_file}" &>/dev/null
        fi
    fi

    [ "${PRINT}" -eq 1 ] && cat "${input_file}"
    rm -f "${CLIPBOARD_PRIVATE_FILE}" 2>/dev/null || true
}

# read from file
if [ -n "${FILE}" ]; then
    copy_file "${FILE}" || exit 1
    exit 0
fi

# read from stdin if available
if [ -p /dev/stdin ]; then
    tmpfile="$(mktemp "/tmp/clip.XXXXXX")"
    cat - > "${tmpfile}"
    copy_file "${tmpfile}"
    status=$?
    rm -f "${tmpfile}"
    exit "${status}"
fi

usage
