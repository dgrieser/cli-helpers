#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
if [ -f "${SCRIPT_DIR}/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib-desktop"
else
    . "${CLI_HELPERS_LIBDIR:-/usr/local/lib/cli-helpers}/lib-desktop"
fi

if [ $# -ne 1 ]; then
    echo "Usage: $(basename "${0}") <title>"
    exit 1
fi

if cli_helpers_is_wayland; then
    cli_helpers_require_command gdbus gdbus || exit 1
    cli_helpers_gnome_window_bridge list | python3 -c '
import json
import sys

needle = sys.argv[1]
for window in json.load(sys.stdin):
    if window.get("title", "") == needle:
        print(window.get("id", ""))
' "${1}"
else
    wmctrl -xl | awk '$5 == "'"${1}"'"' | awk '{print $1}'
fi
