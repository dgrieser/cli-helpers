#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
. "${SCRIPT_DIR}/lib-desktop"

usage() {
    echo "usage: $(basename "${0}") [-c|--clipboard|-p|--primary]" 1>&2
    exit 1
}

clipboard="clipboard"
while [ $# -gt 0 ]; do
    case "${1}" in
        -h|--help)
            usage
            ;;
        -p|--primary)
            clipboard="primary"
            shift
            ;;
        -c|--clipboard)
            clipboard="clipboard"
            shift
            ;;
        *)
            usage
            ;;
    esac
done

if cli_helpers_is_wayland; then
    cli_helpers_require_command wl-copy wl-clipboard || exit 1
    if [ "${clipboard}" = "primary" ]; then
        wl-copy --primary --clear
    else
        wl-copy --clear
    fi
else
    echo | DISPLAY=$(xdisplay) xclip -r -selection "${clipboard}"
fi
