#!/bin/bash

cli_helpers_session_type() {
    if [ "${XDG_SESSION_TYPE:-}" = "wayland" ] || [ -n "${WAYLAND_DISPLAY:-}" ]; then
        echo "wayland"
    else
        echo "x11"
    fi
}

cli_helpers_is_wayland() {
    [ "$(cli_helpers_session_type)" = "wayland" ]
}

cli_helpers_require_command() {
    local command_name="${1}"
    local package_name="${2:-${command_name}}"

    if ! command -v "${command_name}" >/dev/null 2>&1; then
        echo "ERROR: '${command_name}' is required. Install '${package_name}' and retry." 1>&2
        return 1
    fi
}

cli_helpers_repo_dir() {
    cd "$(dirname "${BASH_SOURCE[0]}")" && pwd
}

cli_helpers_gnome_window_bridge() {
    "$(cli_helpers_repo_dir)/gnome-window-bridge" "$@"
}

cli_helpers_gnome_clipboard_bridge() {
    "$(cli_helpers_repo_dir)/gnome-clipboard-bridge" "$@"
}

cli_helpers_gnome_display_config() {
    "$(cli_helpers_repo_dir)/gnome-display-config" "$@"
}

cli_helpers_clipboard_set_text_file() {
    local selection="${1}"
    local input_file="${2}"

    cli_helpers_is_wayland || return 1
    if [ "${selection}" = "both" ]; then
        cli_helpers_gnome_clipboard_bridge set clipboard "${input_file}" >/dev/null 2>&1 &&
            cli_helpers_gnome_clipboard_bridge set primary "${input_file}" >/dev/null 2>&1
    else
        cli_helpers_gnome_clipboard_bridge set "${selection}" "${input_file}" >/dev/null 2>&1
    fi
}

cli_helpers_clipboard_get_text() {
    local selection="${1}"

    cli_helpers_is_wayland || return 1
    cli_helpers_gnome_clipboard_bridge get "${selection}" 2>/dev/null
}

cli_helpers_clipboard_clear_text() {
    local selection="${1}"

    cli_helpers_is_wayland || return 1
    cli_helpers_gnome_clipboard_bridge clear "${selection}" >/dev/null 2>&1
}
