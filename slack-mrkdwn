#!/usr/bin/env python3
import argparse
import sys
import re

from markdown_to_mrkdwn import SlackMarkdownConverter

def main():
    parser = argparse.ArgumentParser(
        description="Convert Markdown file to Slack mrkdwn and print to stdout."
    )
    parser.add_argument(
        "-f", "--file", required=True,
        help="Markdown file to convert, or '-' for stdin"
    )

    args = parser.parse_args()

    try:
        if args.file == '-':
            md_text = sys.stdin.read()
        else:
            with open(args.file, 'r', encoding='utf-8') as f:
                md_text = f.read()

        converter = SlackMarkdownConverter()
        # before converting, replace all "*" width "- ",
        # so the converter creates lists correctly
        md_text = re.sub(r"^\* ", "- ", md_text, flags=re.MULTILINE)
        slack_text = converter.convert(md_text)
        print(slack_text)
        sys.exit(0)
    except Exception as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
