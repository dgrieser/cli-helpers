#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
if [ -f "${SCRIPT_DIR}/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib-desktop"
else
    . "${CLI_HELPERS_LIBDIR:-/usr/local/lib/cli-helpers}/lib-desktop"
fi

usage() {
    echo "usage: $(basename "${0}") [-h|--help] [--ignore-scale] [-r|--raw] <display>" 1>&2
    exit 1
}

error() {
    echo "ERROR: ${1}" 1>&2
}

fail() {
    error "${1}"
    exit 1
}

warning() {
    echo "WARNING: ${1}"
}

geometry_regex="([0-9]+)/[0-9]+x([0-9]+)/[0-9]+\+([0-9]+)\+([0-9]+)"
display=""
apply_scale=1
scale=1
raw=0
while [ "${#}" -gt 0 ]; do
    case "${1}" in
        -h|--help)
            usage
            ;;
        --ignore-scale)
            apply_scale=0
            ;;
        -r|--raw)
            raw=1
            ;;
        *)
            if [ -z "${display}" ]; then
                display="${1}"
            else
                usage
            fi
            ;;
    esac
    shift
done

[ -z "${display}" ] && usage

if cli_helpers_is_wayland; then
    line="$(cli_helpers_gnome_display_config list --geometry --display "${display}")"
    [ -z "${line}" ] && fail "Display '${display}' not found"
    read -r _name x y width height scale <<< "${line}"
    if [ "${apply_scale}" -eq 0 ]; then
        scale=1
    fi
    geometry="${width}x${height}+${x}+${y}"
    if [ "${raw}" -eq 1 ]; then
        echo "${geometry}"
    else
        echo "${width}"
        echo "${height}"
        echo "${x}"
        echo "${y}"
        [ "${apply_scale}" -eq 1 ] && echo "${scale}"
    fi
    exit 0
fi

if [ "${apply_scale}" -eq 1 ]; then
    scale="$(xmllint --xpath "string(//monitor/monitorspec[connector='${display}']/../../scale)" ${HOME}/.config/monitors.xml 2>/dev/null | head -n 1)"
    [ -z "${scale}" ] && warning "Unable to determine scale for display '${display}', defaulting to 1" && scale=1
fi
geometry=$(xrandr --listmonitors | tail -n +2 | grep "${display}$" | awk '{print $3}')
[ -z "${geometry}" ] && fail "Display '${display}' not found"
width=0
height=0
x=0
y=0
if [[ "${geometry}" =~ ${geometry_regex} ]]; then
    width="${BASH_REMATCH[1]}"
    height="${BASH_REMATCH[2]}"
    x="${BASH_REMATCH[3]}"
    y="${BASH_REMATCH[4]}"
    width=$((width / scale))
    height=$((height / scale))
    x=$((x / scale))
    y=$((y / scale))
    geometry="${width}x${height}+${x}+${y}"
elif [ "${raw}" -eq 0 ]; then
    fail "Failed to parse geometry '${geometry}' for display '${display}'"
elif [ "${raw}" -eq 1 ] && [ "${scale}" -ne 1 ]; then
    warning "Unable to parse geometry '${geometry}' for display '${display}', scale '${scale}' will be ignored"
fi

if [ "${raw}" -eq 1 ]; then
    echo "${geometry}"
else
    echo "${width}"
    echo "${height}"
    echo "${x}"
    echo "${y}"
    [ "${apply_scale}" -eq 1 ] && echo "${scale}"
fi
exit 0
