#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${0}")" && pwd)"
if [ -f "${SCRIPT_DIR}/lib/cli-helpers/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib/cli-helpers/lib-desktop"
elif [ -f "${SCRIPT_DIR}/lib-desktop" ]; then
    . "${SCRIPT_DIR}/lib-desktop"
else
    . "${CLI_HELPERS_LIBDIR:-/usr/local/lib/cli-helpers}/lib-desktop"
fi

if [ "$#" -lt 1 ]; then
    echo "Usage: $(basename "${0}") [--type] <key> ..."
    exit 1
fi

type_mode=0

while [ "${#}" -gt 0 ]; do
    case "${1}" in
        --type)
            type_mode=1
            ;;
        *)
            break
            ;;
    esac
    shift
done

# send all arguments as keys
while [ "${#}" -gt 0 ]; do
    if cli_helpers_is_wayland; then
        cli_helpers_require_command ydotool ydotool || exit 1
        if [ "${type_mode}" -eq 1 ]; then
            ydotool type "${1}" || {
                echo "ERROR: ydotool failed. Ensure the ydotool daemon/service is running and accessible." 1>&2
                exit 1
            }
        else
            ydotool key "${1}" || {
                echo "ERROR: ydotool failed. Ensure the ydotool daemon/service is running and accessible." 1>&2
                exit 1
            }
        fi
    else
        if [ "${type_mode}" -eq 1 ]; then
            xdotool type --clearmodifiers "${1}"
        else
            xdotool key --clearmodifiers "${1}"
        fi
    fi
    #sleep 0.1
    shift
done
