#!/usr/bin/env python3
import os
import re
import sys
import time
import argparse
import argcomplete
import subprocess
from collections import deque

# Define the history file path
HISTFILE = os.getenv('HISTFILE')

# Check if the history file exists
if not HISTFILE or not os.path.isfile(HISTFILE):
    print("No history file found.")
    sys.exit(1)

parser = argparse.ArgumentParser()
parser.add_argument("-l", "--lines", type=int, help="Number of tailing lines to return")
parser.add_argument("--no-timestamp", action="store_true", help="Print only the command lines")
parser.add_argument("-e", "--exclude", action="append", default=[], help="Exclude commands matching the given pattern")
argcomplete.autocomplete(parser)
args = parser.parse_args()

exclude_patterns = []
if args.exclude:
    for exclude in args.exclude:
        try:
            exclude_patterns.append(re.compile(exclude))
        except re.error as e:
            print(f"ERROR: Invalid regular expression '{exclude}': {e}", file=sys.stderr)
            sys.exit(1)

def process_line(line, exclude_patterns, last_timestamp, no_timestamp=False):
    line = line.strip()
    if line.startswith('#') and line[1:].isdigit():
        timestamp = int(line[1:])
        new_timestamp = time.strftime("%Y-%m-%dT%H:%M:%S%z", time.localtime(timestamp))
        return new_timestamp, None
    else:
        if any(pattern.search(line) for pattern in exclude_patterns):
            return last_timestamp, None

        if no_timestamp:
            return last_timestamp, line
        else:
            return last_timestamp, f"{last_timestamp} {line}"

if args.lines:
    # Optimized: use tail to get the last lines and stream the output
    num_lines_to_fetch = args.lines * 2  # Fetch more to account for timestamps
    try:
        proc = subprocess.Popen(
            ['tail', '-n', str(num_lines_to_fetch), HISTFILE],
            stdout=subprocess.PIPE, text=True,
        )
    except FileNotFoundError:
        print("Error running 'tail': command not found", file=sys.stderr)
        sys.exit(1)

    history_lines_deque = deque(maxlen=args.lines)
    last_timestamp = None
    with proc.stdout:
        for line in proc.stdout:
            last_timestamp, processed_line = process_line(line, exclude_patterns, last_timestamp, args.no_timestamp)
            if processed_line:
                history_lines_deque.append(processed_line)
    
    # Wait for the process to finish and check for errors
    return_code = proc.wait()
    if return_code != 0:
        print(f"'tail' command exited with error code {return_code}", file=sys.stderr)
        sys.exit(1)

    for history_line in history_lines_deque:
        print(history_line)

else:
    # Original behavior: print all history
    with open(HISTFILE, 'r') as file:
        last_timestamp = None
        for line in file:
            last_timestamp, processed_line = process_line(line, exclude_patterns, last_timestamp, args.no_timestamp)
            if processed_line:
                print(processed_line)
