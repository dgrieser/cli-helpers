#!/usr/bin/env python3
import re
import base64
import argparse
import unicodedata

BASE64_PATTERN = re.compile(
    r'(?<![A-Za-z0-9+/])'                     # Negative lookbehind: no base64 char before
    r'('
        r'(?:[A-Za-z0-9+/]{4})*'              # Any number of 4-character groups
        r'(?:'
            r'[A-Za-z0-9+/]{4}|'             # 4 data chars (no padding) OR
            r'[A-Za-z0-9+/]{3}=|'            # 3 data chars plus one '=' OR
            r'[A-Za-z0-9+/]{2}=='            # 2 data chars plus two '=='
        r')'
    r')'
    r'(?![A-Za-z0-9+/])'                      # Negative lookahead: no base64 char after
)


def is_custom_printable(s, allow_whitespace=True):
    for ch in s:
        cat = unicodedata.category(ch)
        # Category starts with 'C' are control characters.
        if cat.startswith('C'):
            # Optionally allow common whitespace characters.
            if allow_whitespace and ch in '\n\r\t ':
                continue
            return False
    return True

def is_base64(s):
    # Remove newlines and whitespace
    s = s.strip()
    
    if len(s) < 4:
        return False

    # Check if the string matches the base64 format
    match = BASE64_PATTERN.findall(s)
    if not match:
        return False
    
    # Attempt to decode the string
    for m in match:
        base64_str = ""
        if m and isinstance(m, tuple) and len(m) > 1:
            base64_str = str(m[1])
        else:
            base64_str = str(m)

        if base64_str:
            try:
                decoded = base64.b64decode(m)
                decoded_str = decoded.decode('utf-8')
                ok = len(decoded_str) > 10 and is_custom_printable(decoded_str)
                return ok
            except Exception as e:
                pass
    return False

def main():
    parser = argparse.ArgumentParser(description='Find base64-encoded strings in a file')
    parser.add_argument('file', help='The file to search')
    args = parser.parse_args()

    with open(args.file, 'r') as file:
        for line in file:
            if is_base64(line):
                print(line, end='')

if __name__ == '__main__':
    main()
